// Konfigurasi Database
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String       @id @default(cuid())
  name        String?
  username    String?       @unique
  stambuk     String?       @unique // Format PSQL: 1.46.89529
  kelas       String?
  divisi      String?
  password    String
  
  // Fitur Gamifikasi
  rank        Rank         @default(NOVICE) 
  level       Int          @default(1)
  xp          Int          @default(0) // Tambahkan XP untuk tracking progres ke level berikutnya
  
  role        Role         @default(SANTRI)
  createdAt   DateTime     @default(now())
  
  // Relasi
  enrollments Enrollment[]
  courses     Course[]     @relation("TeacherCourses")
  submissions Submission[]
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String?
  teacherId   String
  teacher     User         @relation("TeacherCourses", fields: [teacherId], references: [id])
  
  enrollments Enrollment[]
  assignments Assignment[]
}

model Enrollment {
  id          String    @id @default(cuid())
  studentId   String
  courseId    String
  status      CourseStatus @default(ACTIVE) 
  grade       Int?      
  completedAt DateTime? 

  student     User      @relation(fields: [studentId], references: [id])
  course      Course    @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
}

model Assignment {
  id          String       @id @default(cuid())
  title       String
  content     String       
  dueDate     DateTime?
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id])
  
  submissions Submission[]
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  answer       String?    
  status       SubmissionStatus @default(PENDING)
  score        Int?       
  
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      User       @relation(fields: [studentId], references: [id])
}

// ENUMS (The Logic Gates)
enum Role {
  SANTRI
  USTADZ
  ADMIN
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
}

enum CourseStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum Rank {
  NOVICE
  EXPERT
  MASTER
  PHANTOM
}